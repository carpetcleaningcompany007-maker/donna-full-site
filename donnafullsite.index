<!doctype html><html lang="en-GB"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><title>Services | The Carpet Cleaning Company</title><meta name="description" content="Carpet cleaning, upholstery cleaning, stain treatment and commercial cleaning."><link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"><link rel="stylesheet" href="assets/styles.css"></head><body><div class="topbar"><div class="wrap"><div>Call 07802 563213</div><div>hello@thecarpetcleaningcrew.co.uk</div><div>Shropshire and surrounding areas</div></div></div><header class="header"><div class="wrap nav"><a class="brand" href="index.html"><span class="brand-mark">TC</span><span><strong>The Carpet Cleaning Company</strong><small>Premium cleaning services</small></span></a><nav class="menu"><a href="index.html">Home</a><a href="services.html">Services</a><a href="about.html">About</a><a href="reviews.html">Reviews</a><a href="blog.html">News</a><a href="contact.html">Contact</a></nav><a class="button button-dark" href="contact.html">Get a quote</a></div></header><main><section class="hero"><div class="wrap hero-copy"><div class="eyebrow">Services</div><h1>Professional cleaning services for homes and businesses.</h1><p class="lead">From carpets and upholstery to stain treatment and commercial cleaning, every service is presented clearly and professionally.</p></div></section><section><div class="wrap grid-2"><article class="card"><h3>Carpet cleaning</h3><p>Deep cleaning aimed at freshening appearance, lifting soiling and improving the overall feel of the carpet.</p></article><article class="card"><h3>Upholstery cleaning</h3><p>Careful cleaning for sofas, chairs and upholstered furniture with methods suited to the fabric.</p></article><article class="card"><h3>Stain removal</h3><p>Targeted treatment for spills and marks, with practical advice on realistic expectations where needed.</p></article><article class="card"><h3>Commercial cleaning</h3><p>Cleaning for offices, communal spaces and business environments where presentation matters.</p></article></div></section></main><footer class="footer"><div class="wrap footer-grid"><div class="footer-card"><h3 style="margin-top:0">The Carpet Cleaning Company</h3><p style="color:var(--muted)">Professional carpet, upholstery and specialist cleaning services with a premium, trustworthy approach.</p><div class="badges"><span class="badge">Fully insured</span><span class="badge">Professional equipment</span><span class="badge">Friendly service</span></div></div><div class="footer-card"><h3 style="margin-top:0">Contact</h3><div class="footer-links"><a href="tel:07802563213">07802 563213</a><a href="mailto:hello@thecarpetcleaningcrew.co.uk">hello@thecarpetcleaningcrew.co.uk</a><a href="https://www.thecarpetcleaningcrew.co.uk">thecarpetcleaningcrew.co.uk</a><span>Mon to Sat, 8am to 6pm</span></div></div></div></footer><script src="assets/script.js"></script></body></html>
:root{--bg:#f7fafc;--panel:#fff;--soft:#eef4f8;--text:#12263a;--muted:#5f7285;--line:rgba(18,38,58,.10);--primary:#183b63;--primary-2:#28588c;--gold:#c9a56a;--gold-2:#e8d4ad;--shadow:0 20px 60px rgba(18,38,58,.08);--radius:24px;--wrap:1200px}*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;font-family:Inter,Arial,sans-serif;color:var(--text);background:linear-gradient(180deg,#fbfdff 0%,#f4f8fb 100%);line-height:1.55}a{text-decoration:none;color:inherit}.wrap{width:min(calc(100% - 32px),var(--wrap));margin:0 auto}.topbar{background:var(--primary);color:#fff;font-size:14px}.topbar .wrap{display:flex;justify-content:space-between;gap:18px;flex-wrap:wrap;padding:10px 0}.header{position:sticky;top:0;z-index:30;background:rgba(255,255,255,.90);backdrop-filter:blur(12px);border-bottom:1px solid var(--line)}.nav{display:flex;align-items:center;justify-content:space-between;gap:18px;padding:16px 0}.brand{display:flex;align-items:center;gap:14px}.brand-mark{width:50px;height:50px;border-radius:18px;display:grid;place-items:center;color:#fff;font-weight:900;background:linear-gradient(135deg,var(--primary),var(--primary-2));box-shadow:var(--shadow)}.brand strong{display:block;font-size:15px}.brand small{display:block;color:var(--muted)}.menu{display:flex;gap:18px;align-items:center;flex-wrap:wrap}.menu a{color:var(--muted);font-weight:600}.menu a:hover{color:var(--text)}.button{display:inline-flex;align-items:center;justify-content:center;border-radius:999px;padding:14px 20px;font-weight:800;border:1px solid transparent}.button-primary{background:linear-gradient(135deg,var(--gold),var(--gold-2));color:#1a2230}.button-dark{background:linear-gradient(135deg,var(--primary),var(--primary-2));color:#fff}.button-light{background:#fff;border-color:var(--line);color:var(--text)}.hero{padding:48px 0 30px}.hero-grid{display:grid;grid-template-columns:1.15fr .85fr;gap:24px;align-items:stretch}.hero-copy,.panel,.form-card,.card,.quote,.footer-card{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow)}.hero-copy{padding:40px}.eyebrow{display:inline-flex;padding:9px 14px;border-radius:999px;background:var(--soft);color:var(--primary-2);font-size:13px;font-weight:800;margin-bottom:16px}.hero h1{margin:0 0 14px;font-size:clamp(38px,5vw,68px);line-height:.98;letter-spacing:-.05em}.hero h1 span{color:var(--primary-2)}.lead{font-size:18px;color:var(--muted);max-width:700px}.hero-actions{display:flex;gap:12px;flex-wrap:wrap;margin:24px 0}.trust-row{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px;margin-top:24px}.trust-row div{padding:14px 16px;background:var(--soft);border-radius:18px;color:var(--muted);font-weight:600}.trust-row strong{display:block;color:var(--text)}.form-card{padding:22px;background:linear-gradient(180deg,#fff,#f8fbfd)}.form-card h3{margin:0 0 8px;font-size:28px;letter-spacing:-.03em}.form-card p{margin:0 0 16px;color:var(--muted)}.field{display:grid;gap:8px;margin-bottom:12px}.field label{font-size:14px;font-weight:700;color:var(--text)}input,textarea,select{width:100%;padding:14px 14px;border-radius:16px;border:1px solid var(--line);font:inherit;background:#fff;color:var(--text)}textarea{min-height:120px;resize:vertical}section{padding:28px 0}.section-head{display:flex;justify-content:space-between;align-items:end;gap:18px;margin-bottom:18px}.section-head h2{margin:0;font-size:clamp(30px,4vw,48px);line-height:1;letter-spacing:-.04em}.section-head p{margin:0;color:var(--muted);max-width:720px}.grid-4,.grid-3,.grid-2{display:grid;gap:18px}.grid-4{grid-template-columns:repeat(4,minmax(0,1fr))}.grid-3{grid-template-columns:repeat(3,minmax(0,1fr))}.grid-2{grid-template-columns:repeat(2,minmax(0,1fr))}.card{padding:24px}.card h3{margin:0 0 10px;font-size:22px;letter-spacing:-.03em}.card p{margin:0;color:var(--muted)}.icon{width:52px;height:52px;border-radius:18px;background:var(--soft);color:var(--primary-2);display:grid;place-items:center;font-weight:900;margin-bottom:16px}.split{display:grid;grid-template-columns:1fr 1fr;gap:18px}.dark-panel{background:linear-gradient(135deg,var(--primary),#274d79);color:#fff;padding:30px}.dark-panel p,.dark-panel li{color:rgba(255,255,255,.78)}.list{margin:18px 0 0;padding-left:18px}.quote{padding:24px}.quote p{font-size:18px;margin:0 0 10px}.quote strong{color:var(--primary-2)}.news-thumb{height:210px;background:linear-gradient(135deg,#dbe7f3,#eef4f8);border-radius:18px;margin-bottom:16px}.kicker{font-size:12px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;color:var(--primary-2)}.contact-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:18px}.footer{padding:24px 0 40px}.footer-grid{display:grid;grid-template-columns:1.15fr .85fr;gap:18px}.footer-card{padding:24px}.footer-links{display:grid;gap:10px;color:var(--muted)}.badges{display:flex;gap:10px;flex-wrap:wrap}.badge{padding:10px 14px;border-radius:999px;background:var(--soft);color:var(--primary-2);font-weight:700}.table-like{display:grid;gap:10px}.table-like div{display:flex;justify-content:space-between;gap:12px;padding:14px 16px;border:1px solid var(--line);border-radius:16px;background:#fff}@media (max-width:1024px){.hero-grid,.split,.grid-4,.grid-3,.grid-2,.contact-grid,.footer-grid,.trust-row{grid-template-columns:1fr}}@media (max-width:760px){.menu{display:none}.hero-copy,.form-card,.card,.quote,.footer-card,.dark-panel{padding:22px}.hero-actions{flex-direction:column}.button{width:100%}.section-head{display:block}.section-head p{margin-top:10px}}
document.querySelectorAll('a[href^="#"]').forEach(a=>a.addEventListener('click',e=>{const id=a.getAttribute('href');const el=document.querySelector(id);if(el){e.preventDefault();el.scrollIntoView({behavior:'smooth'})}}));
